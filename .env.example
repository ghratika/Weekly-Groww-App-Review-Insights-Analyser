# ============================================
# Weekly Product Review Pulse — Environment Variables
# ============================================
# Copy this file to .env and fill in your real values.
# NEVER put real secrets in this file — it is committed to version control.
# NEVER commit the .env file itself.

# --- LLM API Keys ---
# Groq is used as the free LLM provider (https://console.groq.com).
# Sign up → Create API key → paste below in your .env file.
GROQ_API_KEY=gsk_your_groq_api_key_here

# --- Remote MCP Server Authentication ---
# Secret key for the Railway-deployed Google Docs & Gmail MCP server.
# This is sent as: Authorization: Bearer <key>
MCP_API_SECRET_KEY=your_mcp_secret_key_here

# --- Google Doc ---
# The ID of the shared Google Doc where weekly reports are appended.
# Example: https://docs.google.com/document/d/<THIS_PART>/edit
GOOGLE_DOC_ID=your_google_doc_id_here
